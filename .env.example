# -----------------------------------------------------------------------------
# PASTE YOUR REAL API KEYS HERE ON YOUR LOCAL MACHINE
# Rename this file from '.env.example' to just '.env' BEFORE you run the bot.
# -----------------------------------------------------------------------------

# Telegram Bot API Token
# Get this from BotFather on Telegram (https://t.me/botfather)
TELEGRAM_TOKEN=your_telegram_bot_token_here

# Groq API Key
# Get this from the Groq Cloud Console (https://console.groq.com/keys)
GROQ_API_KEY=your_groq_api_key_here
